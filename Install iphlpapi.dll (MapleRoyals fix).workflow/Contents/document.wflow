				<key>ActionName</key>
				<string>Run Shell Script</string>
				<key>ActionParameters</key>
				<dict>
					<key>COMMAND_STRING</key>
					<string>DEST="/Applications/CrossOver.app/Contents/SharedSupport/CrossOver/lib/wine/i386-windows/iphlpapi.dll"
DOWNLOADS_DLL="$HOME/Downloads/iphlpapi.dll"

if [ -f "$DOWNLOADS_DLL" ]; then
    SRC="$DOWNLOADS_DLL"
else
    SRC=$(osascript -e 'POSIX path of (choose file with prompt "Could not find iphlpapi.dll in your Downloads folder. Please pick it:" default location (path to downloads folder))' 2&gt;/dev/null)
    if [ -z "$SRC" ]; then
        exit 0
    fi
fi

if osascript -e "do shell script \"cp '$SRC' '$DEST'\" with administrator privileges" 2&gt;/dev/null; then
    osascript -e 'display notification "iphlpapi.dll installed to CrossOver" with title "MapleRoyals Fix"'
else
    osascript -e 'display alert "Install failed" message "Could not copy iphlpapi.dll to CrossOver." as critical'
fi</string>
					<key>CheckedForUserDefaultShell</key>
